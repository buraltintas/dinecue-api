{
  "ConnectionStrings": {
    "DefaultConnection": "Host=<db-host>;Port=<db-port>;Database=<db-name>;Username=<db-user>;Password=<db-password>"
  },
  "Jwt": {
    "Issuer": "DineCue",
    "Audience": "DineCue.Mobile",
    "SigningKey": "replace-with-user-secrets-or-env-var-at-least-32-characters",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 60
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:5173",
    "http://localhost:8081",
    "http://127.0.0.1:8081"
  ],
  "EmailOtp": {
    "ExpiryMinutes": 5,
    "MaxAttempts": 5,
    "ExposeDevOtp": true,
    "StartLimitPerEmailWindow": 3,
    "VerifyLimitPerEmailWindow": 8,
    "EmailWindowMinutes": 15
  },
  "AbuseProtection": {
    "DisposableEmailDomains": [
      "example-disposable.test"
    ],
    "AccountCreationLimitPerEmailWindow": 3,
    "AccountCreationLimitPerProviderWindow": 3,
    "AccountCreationWindowMinutes": 60
  },
  "Email": {
    "Provider": "resend",
    "FromEmail": "hello@example.com",
    "FromName": "DineCue",
    "ReplyToEmail": "info@coffeedictionary.com",
    "BrandLogoUrl": "https://dinecue.com/dinecue-logo.png",
    "BrandIconUrl": "https://dinecue.com/dinecue-icon.png",
    "PrivacyUrl": "https://dinecue.com/privacy",
    "TermsUrl": "https://dinecue.com/terms",
    "ResendApiKey": "set-with-user-secrets-or-environment-variable",
    "AppBaseUrl": "https://app.example.com",
    "Enabled": false,
    "TimeoutSeconds": 10
  },
  "ProductEmail": {
    "WelcomeEnabled": true,
    "MonthlyRecapEnabled": false,
    "MonthlyRecapEnabledByDefault": false,
    "HistoryUrlPath": "/app/history"
  },
  "GoogleAuth": {
    "Enabled": true,
    "ClientId": "set-with-user-secrets-or-environment-variable",
    "AllowedAudiences": [
      "set-with-user-secrets-or-environment-variable"
    ],
    "TimeoutSeconds": 10
  },
  "Recommendation": {
    "UseMockProvider": true
  },
  "Quotas": {
    "MonthlyFree": 5,
    "MonthlyPro": 50
  },
  "GooglePlaces": {
    "ApiKey": "set-with-user-secrets-or-environment-variable",
    "MaxCandidates": 24,
    "DefaultRadiusMeters": 2500,
    "RequestTimeoutSeconds": 12
  },
  "OpenAI": {
    "ApiKey": "set-with-user-secrets-or-environment-variable",
    "Model": "gpt-4.1-mini",
    "RequestTimeoutSeconds": 30
  },
  "Swagger": {
    "Enabled": false
  }
}
