POSTGRES_DB=dinecue
POSTGRES_USER=dinecue
POSTGRES_PASSWORD=replace-with-local-postgres-password
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=dinecue;Username=dinecue;Password=replace-with-local-postgres-password
Jwt__Issuer=DineCue
Jwt__Audience=DineCue.Mobile
Jwt__SigningKey=replace-with-a-long-random-development-secret-at-least-32-bytes
AllowedOrigins__0=http://localhost:3000
AllowedOrigins__1=http://localhost:5173
Recommendation__UseMockProvider=true
Email__Provider=resend
Email__FromEmail=hello@example.com
Email__FromName=DineCue
Email__ReplyToEmail=info@coffeedictionary.com
Email__BrandLogoUrl=https://dinecue.com/dinecue-logo.png
Email__BrandIconUrl=https://dinecue.com/dinecue-icon.png
Email__PrivacyUrl=https://dinecue.com/privacy
Email__TermsUrl=https://dinecue.com/terms
Email__ResendApiKey=replace-with-resend-api-key
Email__AppBaseUrl=https://app.example.com
Email__Enabled=false
Email__TimeoutSeconds=10
ProductEmail__WelcomeEnabled=true
ProductEmail__MonthlyRecapEnabled=false
ProductEmail__MonthlyRecapEnabledByDefault=false
ProductEmail__HistoryUrlPath=/app/history
GoogleAuth__Enabled=true
GoogleAuth__ClientId=replace-with-google-web-client-id
GoogleAuth__AllowedAudiences__0=replace-with-google-web-client-id
GoogleAuth__TimeoutSeconds=10
AbuseProtection__DisposableEmailDomains__0=example-disposable.test
AbuseProtection__AccountCreationLimitPerEmailWindow=3
AbuseProtection__AccountCreationLimitPerProviderWindow=3
AbuseProtection__AccountCreationWindowMinutes=60
GooglePlaces__ApiKey=replace-with-user-secret-or-env-var
GooglePlaces__MaxCandidates=24
GooglePlaces__RequestTimeoutSeconds=12
OpenAI__ApiKey=replace-with-user-secret-or-env-var
OpenAI__Model=gpt-4.1-mini
OpenAI__RequestTimeoutSeconds=30
Quotas__MonthlyFree=5
Quotas__MonthlyPro=50
